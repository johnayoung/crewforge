# Default Agent Configuration Template
# Enhanced with intelligent tool integration patterns
# Variables: agents, all_tools, tools_by_context, project_type, etc.

{% if agents %}
{% for agent in agents %}
{{ agent.role | lower | replace(' ', '_') }}:
  role: {{ agent.role }}
  goal: >
    {{ agent.goal }}
  backstory: >
    {{ agent.backstory }}
  tools:
    {% if all_tools %}
    {% for tool in all_tools %}
    - {{ tool }}
    {% endfor %}
    {% else %}
    - SerperDevTool
    - WebsiteSearchTool
    {% endif %}
  verbose: true

{% endfor %}
{% else %}
# Fallback configuration if no agents provided
default_agent:
  role: Assistant
  goal: >
    Help users accomplish their tasks efficiently and accurately
  backstory: >
    You are a helpful AI assistant with broad knowledge and problem-solving capabilities. 
    You adapt to user needs and provide practical solutions.
  tools:
    {% if all_tools %}
    {% for tool in all_tools %}
    - {{ tool }}
    {% endfor %}
    {% else %}
    - SerperDevTool
    - WebsiteSearchTool
    {% endif %}
  verbose: true
{% endif %}
  {% if enhanced_attributes and enhanced_attributes.get(agent_key) %}
  {% for attr_key, attr_value in enhanced_attributes[agent_key].items() %}
  {{ attr_key }}: {{ attr_value }}
  {% endfor %}
  {% endif %}

{% endfor %}
{% elif agent %}
# Single agent mode
{{ agent.role | lower | replace(' ', '_') }}:
  role: {{ agent.role }}
  goal: >
    {{ agent.goal }}
  backstory: >
    {{ agent.backstory }}
  tools:
    {% for tool in agent.tools %}
    - {{ tool }}
    {% endfor %}
{% else %}
# No agent data provided
# Please provide either 'agents' (dict) or 'agent' (single agent) in the context
{% endif %}
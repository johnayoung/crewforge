# Data Analysis Team Agent Configuration Template
# Optimized for data science and analytics projects with intelligent tool patterns

{% if agents %}
{% for agent in agents %}
{% if "analyst" in agent.role.lower() or "scientist" in agent.role.lower() %}
data_analyst:
  role: {{ agent.role }}
  goal: >
    {{ agent.goal }}
  backstory: >
    {{ agent.backstory }}
  tools:
    {% if data_tools %}
    {% for tool in data_tools %}
    - {{ tool }}
    {% endfor %}
    {% else %}
    - CSVSearchTool
    - ExcelSearchTool
    - JSONSearchTool
    {% endif %}
  verbose: true

{% elif "engineer" in agent.role.lower() %}
data_engineer:
  role: {{ agent.role }}
  goal: >
    {{ agent.goal }}
  backstory: >
    {{ agent.backstory }}
  tools:
    {% if analysis_tools %}
    {% for tool in analysis_tools %}
    - {{ tool }}
    {% endfor %}
    {% else %}
    - DatabaseTool
    - CSVSearchTool
    - ExcelSearchTool
    {% endif %}
  verbose: true

{% else %}
{{ agent.role | lower | replace(' ', '_') }}:
  role: {{ agent.role }}
  goal: >
    {{ agent.goal }}
  backstory: >
    {{ agent.backstory }}
  tools:
    {% if all_tools %}
    {% for tool in all_tools %}
    - {{ tool }}
    {% endfor %}
    {% else %}
    - CSVSearchTool
    - JSONSearchTool
    {% endif %}
  verbose: true

{% endif %}
{% endfor %}
{% else %}
# Default data team configuration
data_analyst:
  role: Data Analyst
  goal: >
    Analyze complex datasets to extract meaningful insights and identify patterns that drive business decisions
  backstory: >
    You are a senior data analyst with expertise in statistical analysis, data visualization, 
    and translating complex data into actionable business insights.
  tools:
    {% if data_tools %}
    {% for tool in data_tools %}
    - {{ tool }}
    {% endfor %}
    {% else %}
    - CSVSearchTool
    - ExcelSearchTool
    - JSONSearchTool
    {% endif %}
  verbose: true

business_analyst:
  role: Business Intelligence Analyst
  goal: >
    Transform data findings into strategic business recommendations and reports
  backstory: >
    You are an experienced business analyst who bridges the gap between technical data analysis 
    and strategic business decision-making.
  tools:
    {% if analysis_tools %}
    {% for tool in analysis_tools %}
    - {{ tool }}
    {% endfor %}
    {% else %}
    - DatabaseTool
    - CSVSearchTool
    - ExcelSearchTool
    {% endif %}
  verbose: true
{% endif %}

ml_engineer:
  role: {{ agents.ml_engineer.role if agents.ml_engineer else "ML Engineer" }}
  goal: >
    {{ project.enhanced_ml_goal or "Deploy and monitor machine learning models in production environments" }}
  backstory: >
    {{ project.enhanced_ml_backstory or "Machine learning engineer with expertise in MLOps and model deployment" }}
  tools: {{ project.ml_tools | default(["scikit_learn", "tensorflow", "pytorch", "mlflow", "kubernetes"]) | tojson }}
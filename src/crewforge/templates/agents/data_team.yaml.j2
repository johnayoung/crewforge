# Data Analysis Team Agent Configuration Template
# Optimized for data science and analytics projects
# Variables: agents, project.enhanced_* values

data_analyst:
  role: {{ agents.data_analyst.role if agents.data_analyst else "Data Analyst" }}
  goal: >
    {{ project.enhanced_analyst_goal or "Analyze complex datasets to extract meaningful insights and patterns" }}
  backstory: >
    {{ project.enhanced_analyst_backstory or "Senior data scientist with expertise in statistical analysis and machine learning" }}
  tools: {{ project.analyst_tools | default(["pandas", "numpy", "matplotlib", "seaborn", "sql_database"]) | tojson }}

data_engineer:
  role: {{ agents.data_engineer.role if agents.data_engineer else "Data Engineer" }}
  goal: >
    {{ project.enhanced_engineer_goal or "Build robust data pipelines and infrastructure for scalable analytics" }}
  backstory: >
    {{ project.enhanced_engineer_backstory or "Experienced data engineer specializing in ETL processes and cloud data platforms" }}
  tools: {{ project.engineer_tools | default(["apache_airflow", "spark", "kafka", "cloud_storage", "sql_database"]) | tojson }}

ml_engineer:
  role: {{ agents.ml_engineer.role if agents.ml_engineer else "ML Engineer" }}
  goal: >
    {{ project.enhanced_ml_goal or "Deploy and monitor machine learning models in production environments" }}
  backstory: >
    {{ project.enhanced_ml_backstory or "Machine learning engineer with expertise in MLOps and model deployment" }}
  tools: {{ project.ml_tools | default(["scikit_learn", "tensorflow", "pytorch", "mlflow", "kubernetes"]) | tojson }}
# Marketing Team Agent Configuration Template  
# Optimized for digital marketing and growth projects
# Variables: agents, project.enhanced_* values

marketing_strategist:
  role: {{ agents.marketing_strategist.role if agents.marketing_strategist else "Marketing Strategist" }}
  goal: >
    {{ project.enhanced_strategist_goal or "Develop comprehensive marketing strategies to drive customer acquisition and retention" }}
  backstory: >
    {{ project.enhanced_strategist_backstory or "Senior marketing professional with 12+ years in digital marketing and growth hacking" }}
  tools: {{ project.strategist_tools | default(["market_research", "analytics_dashboard", "competitor_analysis", "survey_tool"]) | tojson }}

content_creator:
  role: {{ agents.content_creator.role if agents.content_creator else "Content Creator" }}
  goal: >
    {{ project.enhanced_creator_goal or "Create compelling content that engages target audiences and drives conversions" }}
  backstory: >
    {{ project.enhanced_creator_backstory or "Creative content specialist with expertise in multimedia production and storytelling" }}
  tools: {{ project.creator_tools | default(["content_editor", "design_software", "video_editor", "social_media_scheduler"]) | tojson }}

performance_analyst:
  role: {{ agents.performance_analyst.role if agents.performance_analyst else "Performance Analyst" }}
  goal: >
    {{ project.enhanced_analyst_goal or "Monitor and optimize marketing performance across all channels and campaigns" }}
  backstory: >
    {{ project.enhanced_analyst_backstory or "Data-driven marketing analyst specializing in attribution and ROI optimization" }}
  tools: {{ project.analyst_tools | default(["google_analytics", "facebook_insights", "conversion_tracking", "ab_testing_tool"]) | tojson }}